# Optional overrides (leave commented to use application.yml defaults)
#SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/wms?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
#SPRING_DATASOURCE_USERNAME=wms
#SPRING_DATASOURCE_PASSWORD=wms_password

# JWT secret must be 32+ bytes for HS256
#JWT_SECRET=replace-with-your-own-32-bytes-minimum-secret
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_MINUTES=10080
JWT_CLOCK_SKEW_SECONDS=30

APP_ADMIN_EMAIL=xyz@abc.com
APP_ADMIN_PASSWORD=password123
APP_ADMIN_NAME=Super Admin

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
APP_MAIL_FROM=your-email@gmail.com
APP_VERIFY_BASE_URL=http://localhost:5173/verify-email
APP_RESET_BASE_URL=http://localhost:5173/reset-password